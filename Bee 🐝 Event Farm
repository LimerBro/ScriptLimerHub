-- TAB
--========================
local PlayerTab = Window:CreateTab("Player", 4483362458) -- Змінив ID іконки на стандартний

PlayerTab:CreateSection("Farm Systems")

-- FLAGS
local OrbTP = false
local TicketFarm = false
local SnowFarm = false
local GhostTP = false
local MeteorFarm = false

-- SPEED
PlayerTab:CreateSlider({
    Name = "WalkSpeed",
    Range = {16, 200},
    Increment = 1,
    CurrentValue = 16,
    Callback = function(v)
        local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum.WalkSpeed = v end
    end
})

-- TOGGLES
PlayerTab:CreateToggle({
    Name = "Orb Farm",
    CurrentValue = false,
    Callback = function(v) OrbTP = v end
})

PlayerTab:CreateToggle({
    Name = "Ticket Farm",
    CurrentValue = false,
    Callback = function(v) TicketFarm = v end
})

PlayerTab:CreateToggle({
    Name = "Snowflake Farm",
    CurrentValue = false,
    Callback = function(v) SnowFarm = v end
})

PlayerTab:CreateToggle({
    Name = "Ghost System",
    CurrentValue = false,
    Callback = function(v) GhostTP = v end
})

PlayerTab:CreateToggle({
    Name = "Meteor Farm",
    CurrentValue = false,
    Callback = function(v) MeteorFarm = v end
})

--========================
-- MAIN LOOP
--========================
task.spawn(function()
    while task.wait(0.1) do
        local plr = game.Players.LocalPlayer
        local char = plr.Character
        if not char then continue end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        -- ORBS
        if OrbTP then
            local events = workspace:FindFirstChild("Events")
            local spheres = events and events:FindFirstChild("ArcadeSpheres")
            if spheres then
                for _, o in pairs(spheres:GetChildren()) do
                    if o.Name == "ArcadeOrb" then
                        if o:IsA("BasePart") then
                            o.CFrame = hrp.CFrame
                        elseif o:IsA("Model") and o.PrimaryPart then
                            o:SetPrimaryPartCFrame(hrp.CFrame)
                        end
                    end
                end
            end
        end

        -- TICKETS
        if TicketFarm then
            local events = workspace:FindFirstChild("Events")
            if events then
                for _, o in pairs(events:GetDescendants()) do
                    if o.Name == "ArcadeTicket" then
                        local part = o:IsA("Model") and o.PrimaryPart or o:IsA("BasePart") and o
                        if part then
                            hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)
                            task.wait(0.2)
                            local prompt = o:FindFirstChild("PickUpPrompt", true)
                            if prompt then fireproximityprompt(prompt, 1) end
                        end
                    end
                end
            end
        end

        -- SNOWFLAKES
        if SnowFarm then
            for _, o in pairs(workspace:GetChildren()) do
                if o.Name == "SnowflakePickup" then
                    local part = o:IsA("Model") and o.PrimaryPart or o:IsA("BasePart") and o
                    if part then
                        hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)
                        task.wait(0.2)
                        local prompt = o:FindFirstChild("PickUpPrompt", true)
                        if prompt then fireproximityprompt(prompt, 1) end
                    end
                end
            end
        end

        -- GHOST SYSTEM
        if GhostTP then
            local target = hrp.CFrame * CFrame.new(0, 0, -6)
            for _, obj in pairs(workspace:GetChildren()) do
                if obj:IsA("Model") and string.find(obj.Name, "Ghost") then
                    if obj.PrimaryPart then obj:SetPrimaryPartCFrame(target) end
                end
            end
        end

        -- METEOR FARM
        if MeteorFarm then
            local meteor = workspace:FindFirstChild("MeteoronPickup")
            if meteor and meteor.PrimaryPart then
                hrp.CFrame = meteor.PrimaryPart.CFrame + Vector3.new(0, 3, 0)
                task.wait(0.2)
                local prompt = meteor.PrimaryPart:FindFirstChild("PickUpPrompt")
                if prompt then fireproximityprompt(prompt, 1) end
            end
        end
    end -- Кінець циклу while
end) -- Кінець task.spawn
