local PlayerTab = Window:CreateTab("Player", 9856936588)

PlayerTab:CreateSection("Farm Systems")

-- FLAGS
local OrbTP = false
local TicketFarm = false
local SnowFarm = false
local GhostTP = false
local MeteorFarm = false

