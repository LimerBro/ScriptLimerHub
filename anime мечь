local NoClip = false

PTab:CreateToggle({
	Name = "NoClip (проходити крізь стіни)",
	CurrentValue = false,
	Flag = "NoClip",
	Callback = function(Value)

		NoClip = Value

		if NoClip then

			task.spawn(function()

				while NoClip do

					local char = player.Character

					if char then
						for _,v in pairs(char:GetDescendants()) do
							if v:IsA("BasePart") then
								v.CanCollide = false
							end
						end
					end

					task.wait()

				end

			end)

		end

	end
})
