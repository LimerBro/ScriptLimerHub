MiningTab:CreateButton({
	Name = "TP to Secret",
	Callback = function()

		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then return end

		local hrp = char.HumanoidRootPart
		local zones = workspace:FindFirstChild("Zones")

		if zones then

			for _,zone in pairs(zones:GetChildren()) do

				local utility = zone:FindFirstChild("Utility")

				if utility then

					local secret = utility:FindFirstChild("Secret")

					if secret and secret:IsA("BasePart") then

						hrp.CFrame = secret.CFrame + Vector3.new(0,3,0)

						Rayfield:Notify({
							Title = "Secret",
							Content = "Телепорт до Secret",
							Duration = 3
						})

						return
					end

				end

			end

		end

		Rayfield:Notify({
			Title = "Secret",
			Content = "Secret не знайдено",
			Duration = 3
		})

	end
})
