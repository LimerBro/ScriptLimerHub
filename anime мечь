-- ============================================
-- 🤖 AUTO MAZE
-- ============================================

local AutoMaze = false

MiningTab:CreateToggle({
	Name = "Auto Maze Raid",
	CurrentValue = false,
	Flag = "AutoMaze",
	Callback = function(Value)

		AutoMaze = Value

		if AutoMaze then

			task.spawn(function()

				while AutoMaze do

					local maze = workspace:FindFirstChild("Zones") and workspace.Zones:FindFirstChild(SelectedMaze)

					-- якщо Maze пропав
					if not maze then

						Rayfield:Notify({
							Title = "Maze",
							Content = "Maze не знайдено. Очікування 5 секунд...",
							Duration = 3
						})

						task.wait(5)
						continue
					end

					local char = player.Character

					if char and char:FindFirstChild("HumanoidRootPart") then

						local hrp = char.HumanoidRootPart
						local enemiesFolder = workspace:FindFirstChild("Enemies")

						local didSomething = false

						-- ============================================
						-- ENEMIES
						-- ============================================

						if enemiesFolder and #enemiesFolder:GetChildren() > 0 then

							for _,enemy in pairs(enemiesFolder:GetChildren()) do

								if enemy:IsA("Model") then

									local part = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChildWhichIsA("BasePart")

									if part then

										hrp.CFrame = part.CFrame * CFrame.new(0,0,3)

										didSomething = true
										task.wait(0.3)

									end
								end

								if not AutoMaze then break end

							end
						end

						-- ============================================
						-- DOORS
						-- ============================================

						local roomsFolder = maze.Map.Rooms

						if roomsFolder then

							for _,room in pairs(roomsFolder:GetChildren()) do

								local doors = room:FindFirstChild("Doors")

								if doors then

									for _,door in pairs(doors:GetChildren()) do

										local prompt = door:FindFirstChildOfClass("ProximityPrompt")

										if prompt then

											hrp.CFrame = door.CFrame * CFrame.new(0,0,-3)

											task.wait(0.2)

											fireproximityprompt(prompt)

											task.wait(0.4)

											didSomething = true

										end
									end
								end

								if not AutoMaze then break end
							end
						end

						-- ============================================
						-- RESTART MAZE
						-- ============================================

						if not didSomething then

							local start = workspace:FindFirstChild("MazeStart")

							if start then
								hrp.CFrame = start.CFrame + Vector3.new(0,3,0)
							end

							task.wait(2)

						end
					end

					task.wait(0.3)

				end

			end)

		end

	end
})

-- ============================================
-- ⚡ FAST FARM (TP → KILL)
-- ============================================

local FastFarm = false

MiningTab:CreateToggle({
	Name = "Fast Farm Enemies (TP Kill)",
	CurrentValue = false,
	Flag = "FastFarmTP",
	Callback = function(Value)

		FastFarm = Value

		if FastFarm then

			task.spawn(function()

				while FastFarm do

					local char = player.Character
					if not char or not char:FindFirstChild("HumanoidRootPart") then
						task.wait(0.02)
						continue
					end

					local hrp = char.HumanoidRootPart
					local enemiesFolder = workspace:FindFirstChild("Enemies")

					if enemiesFolder then

						for _,enemy in pairs(enemiesFolder:GetChildren()) do

							if not FastFarm then break end

							if enemy:IsA("Model") then

								local part =
									enemy:FindFirstChild("HumanoidRootPart")
									or enemy:FindFirstChildWhichIsA("BasePart")

								if part then

									-- TP до ворога
									hrp.CFrame = part.CFrame * CFrame.new(0,0,3)

									-- чекати поки ворог помре
									repeat
										task.wait(0.01)
									until not enemy.Parent or not FastFarm

								end

							end

						end

					end

					task.wait(0)

				end

			end)

		end

	end
})
