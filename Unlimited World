local SelectedPotion = 10050

local PotionList = {
    ["Big Luck"] = 10050,
    ["Big Damage"] = 10051,
    ["Big Strength"] = 10052,
    ["Big Coins"] = 10053,

    ["Greater Luck"] = 10328,
    ["Greater Damage"] = 10329,
    ["Greater Strength"] = 10330,
    ["Greater Coins"] = 10331,
}

GameTab:CreateDropdown({
    Name = "Potion",
    Options = {
        "Big Luck",
        "Big Damage",
        "Big Strength",
        "Big Coins",
        "Greater Luck",
        "Greater Damage",
        "Greater Strength",
        "Greater Coins"
    },
    CurrentOption = {"Big Luck"},
    MultipleOptions = false,
    Flag = "PotionSelect",
    Callback = function(Options)
        SelectedPotion = PotionList[Options[1]]
    end,
})

GameTab:CreateButton({
    Name = "Craft Potion",
    Callback = function()
        local args = {
            [1] = {
                count = 3,
                id = SelectedPotion
            },
            n = 1,
        }

        game:GetService("ReplicatedStorage").Remotes.PotionMerge:InvokeServer(unpack(args, 1, args.n or #args))
    end,
})

