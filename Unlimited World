local GameTab = Window:CreateTab("Game", null)

-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Variables
local AutoGroupReward = false

-- Toggle
GameTab:CreateToggle({
    Name = "Auto Group Reward",
    CurrentValue = false,
    Flag = "AutoGroupReward",
    Callback = function(Value)
        AutoGroupReward = Value

        task.spawn(function()
            while AutoGroupReward do
                pcall(function()
                    local args = {
                        [1] = nil,
                        n = 1,
                    }

                    ReplicatedStorage.Remotes.ClaimGroupReward:InvokeServer(unpack(args, 1, args.n or #args))
                end)

                task.wait(30) -- перевірка кожні 30 секунд
            end
        end)
    end,
})

