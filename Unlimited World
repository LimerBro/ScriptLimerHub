-- ============================================

GameTab:CreateSection("🎰 Auto Gacha")

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local autoGacha = {}
local delay = 0.2

local gachas = {
    {name = "Breath Amplification W - 1", id = 400001},
    {name = "Elemental Blessing W - 3", id = 400006},
    {name = "Ornament W - 4", id = 400005},
    {name = "Awakening W - 8", id = 400002},
    {name = "Headdress W - 12 ", id = 400008},
    {name = "Talisman W - 18", id = 400007},
    {name = "Mask W - 20", id = 400009},
}


-- TOGGLES
for i, data in ipairs(gachas) do
    autoGacha[i] = false

    GameTab:CreateToggle({
        Name = "Auto " .. data.name,
        CurrentValue = false,
        Callback = function(Value)
            autoGacha[i] = Value

            if Value then
                task.spawn(function()
                    while autoGacha[i] do
                        local args = {
                            [1] = {
                                isAuto = false,
                                machineId = data.id
                            },
                        }

                        ReplicatedStorage.Remotes.RerollOrnament:InvokeServer(unpack(args))
                        task.wait(delay)
                    end
                end)
            end
        end,
    })
end

