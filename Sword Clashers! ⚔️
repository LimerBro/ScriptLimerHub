-- Отримати HRP гравця
local function getHRP()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

-- Плавний політ до цілі
local function flyTo(hrp, targetPart)
    local distance = (hrp.Position - targetPart.Position).Magnitude
    local time = math.clamp(distance / 80, 0.15, 0.6)
    
    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = targetPart.CFrame * CFrame.new(0, 0, -3)}
    )
    tween:Play()
    tween.Completed:Wait()
end

-- Телепорт ворогів до гравця
local function teleportEnemies()
    local enemiesFolder = Workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return end
    
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = character.HumanoidRootPart
    local targetCFrame = hrp.CFrame * CFrame.new(0, 0, -6)
    
    for _, enemy in pairs(enemiesFolder:GetChildren()) do
        if enemy:IsA("Model") then
            if not enemy.PrimaryPart then
                enemy.PrimaryPart = enemy:FindFirstChildWhichIsA("BasePart")
            end
            if enemy.PrimaryPart then
                enemy:SetPrimaryPartCFrame(targetCFrame)
            end
        elseif enemy:IsA("BasePart") then
            enemy.CFrame = targetCFrame
        end
    end
end

